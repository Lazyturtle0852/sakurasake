# frozen_string_literal: true

require "bundler/setup"

task :environment do
  ENV["RACK_ENV"] ||= "development"
end

namespace :db do
  desc "feed_items にシードデータを投入する（要 DATABASE_URL）"
  task seed: :environment do
    load File.expand_path("db/seeds.rb", __dir__)
  end
end

namespace :export do
  desc "現在のDB状態を埋め込んだ静的サイトを書き出す（要 DATABASE_URL）"
  task static: :environment do
    load File.expand_path("static_export.rb", __dir__)
    Sakurasake::StaticExporter.run!
  end
end
